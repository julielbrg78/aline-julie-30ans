# Copiez ce fichier en ".env" (ou renseignez ces variables dans Vercel)
# pour activer le mode "partagé" (RSVP / mur de photos / livre d'or visibles par tous).
# SANS ces variables, le site fonctionne quand même : les données sont alors
# enregistrées uniquement sur l'appareil de chaque visiteur.

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique
